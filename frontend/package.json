{
  "name": "cojournalist-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --strategy localStorage globalVariable baseLocale",
    "dev:raw": "npm run paraglide:compile && svelte-kit sync && vite dev",
    "dev": "npm run dev:raw",
    "dev:supabase-local-demo": "bash ../scripts/dev/run-frontend-supabase-local-demo.sh",
    "build": "npm run paraglide:compile && svelte-kit sync && vite build",
    "preview": "svelte-kit sync && vite preview",
    "check": "npm run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "test": "npm run paraglide:compile && svelte-kit sync && vitest run --config vitest.config.ts",
    "test:coverage": "npm run paraglide:compile && svelte-kit sync && vitest run --config vitest.config.ts --coverage",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.0.18",
    "baseline-browser-mapping": "^2.9.19",
    "eslint": "^10.2.0",
    "jsdom": "29.0.2",
    "postcss": "^8.5.10",
    "svelte": "^5.55.4",
    "svelte-check": "^4.1.3",
    "tailwindcss": "^4.2.4",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@inlang/paraglide-js": "^2.16.0",
    "@supabase/supabase-js": "2.102.1",
    "dompurify": "^3.2.3",
    "lucide-svelte": "^0.468.0",
    "marked": "^17.0.0"
  },
  "overrides": {
    "cookie": "0.7.2",
    "uuid": "14.0.0"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "npm": ">=10.0.0 <11.0.0"
  }
}
