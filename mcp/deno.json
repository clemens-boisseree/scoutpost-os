{
  "tasks": {
    "test": "deno test lib/ --allow-env --allow-read",
    "run": "deno run --allow-net --allow-env --allow-read scout-mcp.ts",
    "compile-mac-arm": "deno compile --target aarch64-apple-darwin --output dist/scout-mcp-darwin-arm64 --allow-net --allow-env --allow-read scout-mcp.ts",
    "compile-mac-x86": "deno compile --target x86_64-apple-darwin --output dist/scout-mcp-darwin-x86_64 --allow-net --allow-env --allow-read scout-mcp.ts",
    "compile-linux-arm": "deno compile --target aarch64-unknown-linux-gnu --output dist/scout-mcp-linux-arm64 --allow-net --allow-env --allow-read scout-mcp.ts",
    "compile-linux-x86": "deno compile --target x86_64-unknown-linux-gnu --output dist/scout-mcp-linux-x86_64 --allow-net --allow-env --allow-read scout-mcp.ts",
    "compile-all": "deno task compile-mac-arm && deno task compile-mac-x86 && deno task compile-linux-arm && deno task compile-linux-x86"
  },
  "fmt": { "indentWidth": 2, "semiColons": true }
}
