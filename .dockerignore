# Frontend
frontend/node_modules
frontend/.svelte-kit
frontend/build
frontend/.env
frontend/.env.local
frontend/.env.*.local
# NOTE: frontend/.env.production is committed and MUST reach the build
# context. Vite reads it during `npm run build` to substitute
# `import.meta.env.PUBLIC_*` references in the bundle. The previous
# `frontend/.env.*` glob excluded it, leaving import.meta.env.PUBLIC_SUPABASE_URL
# undefined → "" → broken Supabase client (2026-04-21 cutover bug).

